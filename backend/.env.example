# ─── SafeNight Backend — Environment Variables ───
# Copy this to .env and fill in your values.

# Allowed origins for CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:8083,http://localhost:19006,http://localhost:3000,http://localhost:19000,http://localhost:3004

# Port (overridden per service in npm scripts)
PORT=3001

# OpenAI API key (server-side only, NEVER exposed to clients)
OPENAI_API_KEY=

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
DB_PASSWORD=

# ─── Stripe (Subscription Service, port 3004) ───
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_YOUR_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_YOUR_SECRET_HERE

# Stripe Price ID — create a Product in Stripe Dashboard
# then copy the Price ID here (Guarded plan)
STRIPE_PRICE_PRO=price_YOUR_PRO_ID

# Stripe Price ID for Family & Friends Pack
STRIPE_PRICE_FAMILY=price_YOUR_FAMILY_ID

# Frontend URL for Stripe Checkout redirect callbacks
FRONTEND_URL=http://localhost:8083

# Subscription service URL (used by user service for cross-referencing)
SUBSCRIPTION_SERVICE_URL=http://localhost:3004

{
  "name": "plymhack2026new",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:web": "npx expo export --platform web",
    "test:frontend": "jest --config jest.frontend.config.cjs",
    "test:frontend:watch": "jest --config jest.frontend.config.cjs --watch",
    "test:frontend:coverage": "jest --config jest.frontend.config.cjs --coverage --runInBand",
    "test:backend": "npm --prefix ./backend run test:coverage",
    "test:all": "npm run test:frontend && npm run test:backend",
    "test:all:coverage": "npm run test:frontend:coverage && npm run test:backend",
    "guard:artifacts": "bash ./scripts/guard-artifacts.sh",
    "guard:artifacts:ci": "bash ./scripts/guard-artifacts.sh --ci",
    "install:hooks": "bash ./scripts/install-git-hooks.sh",
    "lint": "expo lint",
    "build:android": "node ./scripts/bump-android-version-code.js && eas build --platform android --profile production",
    "build:android:local": "node ./scripts/bump-android-version-code.js && ANDROID_HOME=$HOME/Library/Android/sdk ANDROID_SDK_ROOT=$HOME/Library/Android/sdk eas build --platform android --profile production --local",
    "submit:android": "eas submit --platform android",
    "update": "eas update --branch production",
    "update:android": "eas update --platform android --branch production"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "expo": "~54.0.33",
    "expo-camera": "~17.0.10",
    "expo-constants": "~18.0.13",
    "expo-device": "~8.0.10",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-linking": "~8.0.11",
    "expo-location": "~19.0.8",
    "expo-notifications": "~0.32.16",
    "expo-pip": "^2.0.1",
    "expo-router": "~6.0.23",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-updates": "^29.0.16",
    "expo-web-browser": "~15.0.10",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-native": "^0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-maps": "1.20.1",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "~0.21.0",
    "react-native-webview": "13.15.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/react": "~19.1.0",
    "@types/react-test-renderer": "^19.1.0",
    "cli-cursor": "^2.1.0",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "jest": "^29.7.0",
    "jest-expo": "^55.0.16",
    "typescript": "~5.9.2"
  },
  "expo": {
    "doctor": {
      "appConfigFieldsNotSyncedCheck": {
        "enabled": false
      },
      "reactNativeDirectoryCheck": {
        "exclude": [
          "expo-pip"
        ]
      }
    }
  },
  "private": true
}

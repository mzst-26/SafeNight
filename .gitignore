# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Environment secrets — NEVER commit API keys or env files
.env
.env.local
.env.*.local
.env.production
backend/.env

# Database schema files
*.sql

# Summaries / notes
Summary.txt

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Upload keystore (signing secrets)
android/app/upload-keystore.jks

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo

app-example

# generated native folders
/ios
# android source is committed (custom native modules + signing config)
# ignore only build artifacts and sensitive files:
android/app/build/
android/build/
android/.gradle/
android/app/release.keystore
android/local.properties
.env
.env.production

# IDE settings (user-specific, should not be committed)
.vscode/
.idea/
*.iml
*.swp
*.swo
# IDE
.idea/

# Build artifacts
android_build_log.txt
test_map.png

# Google Play service account (for automated submission)
google-play-service-account.json

# Markdown documentation files (notes, deployment guides, environment docs)
*.md

# SQL files (database schema/migration files - keep out of repo)
*.sql

# Environment files (all variants - never commit real secrets)
.env*
